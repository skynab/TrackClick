<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="TrackClick"
           Manufacturer="Anthony Lazzaro"
           Version="1.0.0"
           UpgradeCode="7E8A4B2C-1F3D-4E9A-8B6C-2D5F0A3E7B1C"
           Language="1033"
           Compressed="yes">

    <SummaryInformation />
    <MediaTemplate EmbedCab="yes" />

    <!-- Installer/ARP icon: package box graphic -->
    <Icon Id="TrackClick.ico" SourceFile="TrackClick.ico" />
    <Property Id="ARPPRODUCTICON" Value="TrackClick.ico" />
    <!-- App icon: circle/cursor logo, used on shortcuts -->
    <Icon Id="TrackClickApp.ico" SourceFile="..\icons\TrackClick.ico" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of TrackClick is already installed." />

    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="TrackClick" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="TrackClick" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- AppFiles ComponentGroup is generated at build time by the workflow -->
    <ComponentGroup Id="Shortcuts">
      <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="*">
        <Shortcut Id="AppStartMenuShortcut"
                  Name="TrackClick"
                  Description="Virtual mouse / dwell clicker"
                  Target="[INSTALLFOLDER]TrackClick.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="TrackClickApp.ico" />
        <RemoveFolder Id="CleanupAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\TrackClick\TrackClick"
                       Name="StartMenuShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
        <Shortcut Id="AppDesktopShortcut"
                  Name="TrackClick"
                  Description="Virtual mouse / dwell clicker"
                  Target="[INSTALLFOLDER]TrackClick.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="TrackClickApp.ico" />
        <RegistryValue Root="HKCU"
                       Key="Software\TrackClick\TrackClick"
                       Name="DesktopShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="ProductFeature" Title="TrackClick" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

  </Package>
</Wix>
